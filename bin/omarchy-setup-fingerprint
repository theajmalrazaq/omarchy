#!/bin/bash

# Omarchy Fingerprint Manager (Arch Wiki / T480s Edition)
# Functions: Install, Enroll, Suspend-Fix (Systemd), Remove
# Version: Wiki.Standard

set -e

# --- Configuration ---
G='\033[0;32m'
R='\033[0;31m'
Y='\033[1;33m'
B='\033[1;34m'
NC='\033[0m'

REAL_USER="${SUDO_USER:-$USER}"
REAL_HOME=$(getent passwd "$REAL_USER" | cut -d: -f6)
#HYPRLOCK_CONF="$REAL_HOME/.config/hypr/hyprlock.conf"

# --- Helpers ---
log_ok() { echo -e "${G}󰄬 ${NC}$1"; }
log_err() { echo -e "${R}󰅚 ${NC}$1"; }
log_info() { echo -e "${B}󰋼 ${NC}$1"; }
log_step() { echo -e "\n${Y}󰚀 $1${NC}"; }

# --- Feature: Removal ---
remove_all() {
    log_step "REMOVING Fingerprint System..."
    
    # 1. Clean PAM
    log_info "Cleaning PAM stacks..."
    sudo grep -l "pam_fprintd.so" /etc/pam.d/* 2>/dev/null | xargs -I {} sudo sed -i '/pam_fprintd\.so/d' {} || true

    # 2. Stop Services
    log_info "Stopping services..."
    sudo systemctl disable --now python3-validity.service open-fprintd.service open-fprintd-suspend.service open-fprintd-resume.service fingerprint-restart.service 2>/dev/null || true

    # 3. Remove Hooks & Custom Units
    sudo rm -f /usr/lib/systemd/system-sleep/fingerprint-wakeup.sh
    sudo rm -f /etc/systemd/system/fingerprint-restart.service
    sudo rm -f /etc/udev/rules.d/99-fingerprint-power.rules
    sudo systemctl daemon-reload

    # 4. Uninstall Packages
    log_info "Uninstalling packages..."
    pkgs=$(pacman -Q | grep -E "fprint|validity" | awk '{print $1}' || true)
    if [ -n "$pkgs" ]; then
        sudo pacman -Rns --noconfirm $pkgs 2>/dev/null || sudo pacman -Rdd --noconfirm $pkgs 2>/dev/null || true
    fi

    # 5. Restore UI
#    if [ -f "$HYPRLOCK_CONF" ]; then
        log_info "Restoring Hyprlock UI..."
#        sed -i 's/placeholder_text = .*/placeholder_text = Enter Password/' "$HYPRLOCK_CONF" 2>/dev/null || true
#        sed -i 's/fail_text = .*/fail_text = <i>Authentication Failed (Attempt $ATTEMPTS)<\/i>/' "$HYPRLOCK_CONF" 2>/dev/null || true
    fi

    log_ok "Fingerprint system completely removed."
    exit 0
}

# --- Feature: Install Drivers ---
install_drivers() {
    log_step "Installing Drivers..."
    
    # Clean conflicts
    if pacman -Qq fprintd >/dev/null 2>&1; then
        log_info "Removing conflicting 'fprintd'..."
        sudo pacman -Rdd --noconfirm fprintd libfprint 2>/dev/null || true
    fi

    # Install dependencies
    sudo pacman -S --needed --noconfirm base-devel usbutils python-setuptools python-pip >/dev/null

    # Install AUR packages (forcing system path to avoid 'mise' conflicts)
    export PATH="/usr/bin:/bin:$PATH"
    yay -S --noconfirm --needed fprintd-clients-git open-fprintd python-validity >/dev/null
    log_ok "Drivers installed."
}

# --- Feature: Suspend Fix (Arch Wiki Method) ---
install_suspend_fix() {
    log_step "Installing Arch Wiki Suspend Fix..."
    
    # Create the restart service service recommended by Arch Wiki
    sudo tee /etc/systemd/system/fingerprint-restart.service >/dev/null <<SERVICE_EOF
[Unit]
Description=Restart services to fix fingerprint integration
After=suspend.target hibernate.target hybrid-sleep.target suspend-then-hibernate.target

[Service]
Type=oneshot
ExecStart=/usr/bin/systemctl restart open-fprintd.service python3-validity.service

[Install]
WantedBy=suspend.target hibernate.target hybrid-sleep.target suspend-then-hibernate.target
SERVICE_EOF

    sudo chmod 644 /etc/systemd/system/fingerprint-restart.service
    sudo systemctl daemon-reload
    sudo systemctl enable fingerprint-restart.service
    
    # Also clean up previous "Nuclear" attempt to avoid conflicts
    if [ -f /usr/lib/systemd/system-sleep/fingerprint-wakeup.sh ]; then
        log_info "Removing old nuclear wake script to use standard service instead..."
        sudo rm /usr/lib/systemd/system-sleep/fingerprint-wakeup.sh
    fi
    
    log_ok "Suspend restart service active."
}

# --- Feature: Configuration ---
configure_system() {
    log_step "Configuring Authentication & UI..."

    # PAM Configuration
    for file in /etc/pam.d/sudo /etc/pam.d/polkit-1 /etc/pam.d/hyprlock; do
        if [ -f "$file" ]; then
            sudo sed -i '/pam_fprintd\.so/d' "$file"
            sudo sed -i '1i auth    sufficient pam_fprintd.so' "$file"
        fi
    done

    # Hyprlock UI Updates
#    if [ -f "$HYPRLOCK_CONF" ]; then
        # Add Fingerprint Icon
#        sed -i 's/placeholder_text = .*/placeholder_text = <span> Enter Password 󰈷 <\/span>/' "$HYPRLOCK_CONF"
        # Enable explicit error messages
#        sed -i 's/fail_text = .*/fail_text = <b>$FAIL<\/b> <i>($ATTEMPTS)<\/i>/' "$HYPRLOCK_CONF"
#        sed -i 's/fade_on_empty = true/fade_on_empty = false/' "$HYPRLOCK_CONF"
    fi
    log_ok "System configured."
}

# --- Main Execution ---

if [[ "$1" == "--remove" ]]; then
    remove_all
fi

log_step "Initializing Fingerprint Setup"

# 1. Check Hardware
if ! lsusb | grep -iq "06cb"; then
    log_err "Synaptics 06cb fingerprint sensor not found."
    exit 1
fi
log_ok "Sensor detected."

# 2. Install
install_drivers
install_suspend_fix

# 3. Configure
configure_system

# 4. Activate
log_step "Activating Hardware..."
sudo systemctl enable --now python3-validity.service open-fprintd.service >/dev/null 2>&1

# Initial firmware load
log_info "Initializing firmware..."
# We try to list devices to force firmware load
for i in {1..3}; do
    if sudo fprintd-list "$REAL_USER" >/dev/null 2>&1; then
        break
    fi
    sudo systemctl restart python3-validity.service
    sleep 3
done

# 5. Enroll
log_step "Enrollment"

# Wait for device to be ready
log_info "Checking device status..."
DEVICE_READY=0
for i in {1..15}; do
    if sudo fprintd-list "$REAL_USER" >/dev/null 2>&1; then
        DEVICE_READY=1
        break
    fi
    echo -n "."
    sleep 1
done
echo ""

if [ $DEVICE_READY -eq 0 ]; then
    log_err "Device failed to initialize. Try rebooting."
    exit 1
fi

# Check if already enrolled
if sudo fprintd-list "$REAL_USER" | grep -q "right-index-finger"; then
    log_ok "Fingerprint already enrolled!"
    log_info "Verifying match..."
    if fprintd-verify; then
        log_ok "Verification Successful!"
        echo -e "\n${G}Setup Complete! You are ready to go.${NC}"
        exit 0
    else
        log_err "Verification failed. Proceeding to re-enroll."
    fi
fi

log_info "Ready to enroll. Place your RIGHT INDEX FINGER on the sensor."
if sudo fprintd-enroll "$REAL_USER"; then
    log_ok "Fingerprint successfully enrolled!"
    log_info "Verifying..."
    fprintd-verify && log_ok "Verification Passed."
    echo -e "\n${G}Done! You can now use your fingerprint for Login, Sudo, and Lock Screen.${NC}"
else
    log_err "Enrollment failed. Try running this script again."
    exit 1
fi
